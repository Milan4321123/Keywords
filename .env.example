# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI Configuration (for embeddings, chat, and transcription)
OPENAI_API_KEY=sk-your-openai-key

# Recommended free hosted open-weight chat provider (Groq)
# Used by table/metric design, reports, routing, and provider-based AI answers.
# Get a key at https://console.groq.com/keys
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_your-groq-key
# GROQ_MODEL=openai/gpt-oss-120b
# GROQ_FAST_MODEL=openai/gpt-oss-20b

# Optional: run against any OpenAI-compatible endpoint (Ollama, vLLM, Together)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_CHAT_MODEL=llama3.1:8b
# OPENAI_FAST_MODEL=llama3.1:8b
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002   # must output 1536 dims (pgvector schema)

# Optional: use Anthropic for routing/answers (AI_PROVIDER=anthropic)
# AI_PROVIDER=openai
# ANTHROPIC_API_KEY=sk-ant-...
